---
import Base from '../layouts/Base.astro';
import { products } from '../data/products';
import { url } from '../lib/site';

const order = ['speed-rf', 'rf-shot', 'av-calc', 'fiche-tech', 'reperages'];
const tools = order
  .map((slug) => products.find((p) => p.slug === slug))
  .filter((p): p is (typeof products)[number] => Boolean(p));
---

<Base title="À propos — Arnisound Tools" description="La marque Arnisound Tools : des outils web pensés et conçus par un professionnel du spectacle vivant et de l'événementiel.">
  <section class="section">
    <div class="container about">
      <span class="eyebrow">La marque</span>
      <h1>Arnisound Tools</h1>
      <p class="lead">
        Arnisound Tools, ce sont des outils web pour le spectacle vivant, l'audiovisuel et
        l'événementiel, développés par un professionnel du secteur. L'idée est simple : des
        outils qui répondent à de vrais besoins du terrain, sans usine à gaz, accessibles à
        tous les budgets.
      </p>

      <!-- LA GENÈSE -->
      <h2 class="about__h2">La genèse</h2>
      <p class="about__p">
        Tout part du terrain : un plan de fréquences à refaire en urgence avant l'ouverture des
        portes, un repérage griffonné sur un carnet, un calcul de puissance vérifié trois fois
        sur un coin de table. Les logiciels « pros » existent, mais ils sont chers, complexes,
        et souvent en anglais. Arnisound Tools est né de l'envie d'avoir enfin des outils
        <strong>simples, rapides et en français</strong>, faits par quelqu'un qui connaît la
        régie de l'intérieur.
      </p>

      <!-- LA DÉMARCHE -->
      <h2 class="about__h2">La démarche</h2>
      <div class="grid grid--2" style="margin-top: 1.5rem;">
        <div class="card">
          <h3>Du terrain, pas du labo</h3>
          <p class="text-muted">
            Chaque outil naît d'un problème concret rencontré en régie, en tournée ou en presta.
            Pas de fonctionnalité gadget : ce qui sert, point.
          </p>
        </div>
        <div class="card">
          <h3>Simple et rapide</h3>
          <p class="text-muted">
            Trois infos et un résultat. On va droit au but, parce que sur le terrain le temps
            manque toujours.
          </p>
        </div>
        <div class="card">
          <h3>En français</h3>
          <p class="text-muted">
            Le vocabulaire métier et le contexte réglementaire du secteur (ARCOM/ANFR, TNT…),
            dans votre langue.
          </p>
        </div>
        <div class="card">
          <h3>Accessible</h3>
          <p class="text-muted">
            Sur mobile, sans installation, à des prix pensés pour les intermittents, techniciens
            et prestataires régionaux. Paiement unique, pas d'abonnement caché.
          </p>
        </div>
      </div>

      <!-- LES OUTILS -->
      <h2 class="about__h2">Les outils</h2>
      <div class="about__tools">
        {tools.map((t) => (
          <a href={url('/' + t.slug)} class="about__tool">
            {t.image && <img src={url(t.image)} alt="" width="46" height="46" loading="lazy" />}
            <div>
              <strong>{t.name}</strong>
              <span class="text-muted">{t.tagline}</span>
            </div>
          </a>
        ))}
      </div>

      <div class="contact card">
        <div>
          <h2>Une question, une idée d'outil ?</h2>
          <p class="text-muted">Le retour du terrain fait avancer les outils. Écrivez-nous.</p>
        </div>
        <a href="mailto:contact@arnisoundtools.com" class="btn btn--primary">Nous contacter</a>
      </div>
    </div>
  </section>
</Base>

<style>
  .about { max-width: 820px; }
  .about h1 { margin-top: 0.75rem; }
  .about .lead { margin-top: 1.25rem; }
  .about__h2 { margin-top: 3rem; }
  .about__p { margin-top: 1rem; color: var(--text-muted); line-height: 1.75; }
  .about__p strong { color: var(--text); }

  .about__tools { margin-top: 1.5rem; display: grid; gap: 0.75rem; }
  .about__tool {
    display: flex; align-items: center; gap: 1rem;
    padding: 0.9rem 1.1rem;
    border: 1px solid var(--border); border-radius: var(--radius);
    background: var(--surface);
    transition: border-color 0.15s ease, transform 0.15s ease;
  }
  .about__tool:hover { border-color: var(--accent); transform: translateY(-2px); }
  .about__tool img { width: 46px; height: 46px; flex: none; }
  .about__tool div { display: flex; flex-direction: column; gap: 0.15rem; }
  .about__tool span { font-size: 0.9rem; }

  .contact {
    display: flex;
    align-items: center;
    justify-content: space-between;
    gap: 2rem;
    flex-wrap: wrap;
    margin-top: 3rem;
    padding: 2rem;
  }
</style>
