---
import Base from '../layouts/Base.astro';
---

<Base title="Page introuvable — Arnisound Tools">
  <section class="section text-center" style="min-height: 50vh; display: grid; place-content: center;">
    <div class="container">
      <span class="eyebrow">Erreur 404</span>
      <h1 style="margin-top: 0.75rem;">Cette page n'existe pas</h1>
      <p class="lead mx-auto" style="margin-top: 1rem;">Le lien est peut-être cassé, ou la page a été déplacée.</p>
      <a href="/" class="btn btn--primary" style="margin-top: 1.5rem;">Retour à l'accueil</a>
    </div>
  </section>
</Base>
