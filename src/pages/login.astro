---
import Base from '../layouts/Base.astro';
---

<!-- MAQUETTE — formulaire non branché. Auth (Worker + JWT + D1) à venir. -->
<Base title="Connexion — Arnisound Tools" bare={true}>
  <div class="auth">
    <div class="auth__panel">
      <a href="/" class="brand">
        <span class="brand__mark" aria-hidden="true">A</span>
        <span>Arnisound<span class="brand__accent">Tools</span></span>
      </a>
      <h1>Connexion</h1>
      <p class="text-muted">Accédez à vos outils et licences.</p>

      <form class="auth__form" data-demo>
        <label>
          <span>Email</span>
          <input type="email" name="email" placeholder="vous@exemple.fr" autocomplete="email" required />
        </label>
        <label>
          <span>Mot de passe</span>
          <input type="password" name="password" placeholder="••••••••" autocomplete="current-password" required />
        </label>
        <button type="submit" class="btn btn--primary btn--block">Se connecter</button>
        <p class="auth__demo-note" data-demo-note hidden>
          🔧 Démo : l'authentification sera branchée sur Cloudflare Workers + D1.
        </p>
      </form>

      <p class="auth__switch text-muted">
        Pas encore de compte ? <a href="/dashboard">Créer un compte gratuit</a>
      </p>
    </div>
    <div class="auth__aside" aria-hidden="true">
      <div class="auth__glow"></div>
      <blockquote>« Les outils du terrain, par des gens du terrain. »</blockquote>
    </div>
  </div>
</Base>

<style>
  .auth { display: grid; grid-template-columns: 1fr 1fr; min-height: 100vh; }
  .auth__panel {
    display: flex;
    flex-direction: column;
    justify-content: center;
    gap: 0.5rem;
    padding: clamp(2rem, 6vw, 5rem);
    max-width: 480px;
    margin-inline: auto;
    width: 100%;
  }
  .brand { display: inline-flex; align-items: center; gap: 0.6rem; font-weight: 700; margin-bottom: 1.5rem; }
  .brand__mark {
    display: grid; place-items: center;
    width: 32px; height: 32px; border-radius: 8px;
    background: var(--accent); color: var(--accent-contrast);
    font-weight: 800; font-family: var(--font-mono);
  }
  .brand__accent { color: var(--accent); }
  .auth__panel h1 { font-size: 2rem; }

  .auth__form { display: flex; flex-direction: column; gap: 1rem; margin-top: 1.5rem; }
  .auth__form label { display: flex; flex-direction: column; gap: 0.4rem; font-size: 0.9rem; }
  .auth__form input {
    padding: 0.8rem 1rem;
    background: var(--surface);
    border: 1px solid var(--border);
    border-radius: var(--radius-sm);
    color: var(--text);
    font: inherit;
  }
  .auth__form input:focus { outline: none; border-color: var(--accent); }
  .auth__demo-note { font-size: 0.85rem; color: var(--warn); }

  .auth__switch { margin-top: 1.5rem; font-size: 0.9rem; }
  .auth__switch a { color: var(--accent); }

  .auth__aside { position: relative; overflow: hidden; border-left: 1px solid var(--border); background: var(--bg-soft); display: grid; place-items: center; padding: 3rem; }
  .auth__glow { position: absolute; inset: 0; background: radial-gradient(circle at 50% 40%, var(--accent-soft), transparent 60%); }
  .auth__aside blockquote { position: relative; max-width: 22ch; font-size: 1.5rem; font-weight: 600; line-height: 1.3; letter-spacing: -0.01em; }

  @media (max-width: 820px) {
    .auth { grid-template-columns: 1fr; }
    .auth__aside { display: none; }
  }
</style>

<script>
  // Démo : empêche l'envoi réel tant que l'auth n'est pas branchée.
  const form = document.querySelector('[data-demo]');
  const note = document.querySelector('[data-demo-note]');
  form?.addEventListener('submit', (e) => {
    e.preventDefault();
    note?.removeAttribute('hidden');
  });
</script>
