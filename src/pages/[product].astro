---
import Base from '../layouts/Base.astro';
import { products, getProduct } from '../data/products';
import { url } from '../lib/site';

export function getStaticPaths() {
  return products.map((p) => ({ params: { product: p.slug } }));
}

const { product } = Astro.params;
const p = getProduct(product!);
if (!p) return Astro.redirect('/404');

const comingSoon = Boolean(p.comingSoon);
const ctaExternal = Boolean(p.appUrl);
const ctaLabel = p.appUrl
  ? "Ouvrir l'app — gratuit"
  : p.free
    ? 'Créer un compte gratuit'
    : `Acheter — ${p.price}`;
const ctaHref = p.appUrl ?? url('/login'); // TODO: brancher Lemon Squeezy
const ctaAttrs = ctaExternal ? { target: '_blank', rel: 'noopener noreferrer' } : {};
---

<Base title={`${p.name} — Arnisound Tools`} description={p.tagline}>
  <section class="product-hero">
    <div class="container product-hero__inner">
      <div>
        <a href={url('/')} class="back-link">← Tous les outils</a>
        <span class="eyebrow">{p.audience}</span>
        <h1>{p.name}</h1>
        <p class="lead">{p.tagline}</p>
        {p.pitch && <p class="product-hero__pitch text-muted">{p.pitch}</p>}
        {p.heroPoints && (
          <ul class="hero-points">
            {p.heroPoints.map((pt) => <li>{pt}</li>)}
          </ul>
        )}
        <div class="product-hero__cta">
          {comingSoon ? (
            <span class="btn btn--primary is-disabled" aria-disabled="true">Bientôt disponible</span>
          ) : (
            <a href={ctaHref} class="btn btn--primary" {...ctaAttrs}>{ctaLabel}</a>
          )}
          {(!p.free || comingSoon) && <span class="text-muted">{p.priceNote}</span>}
        </div>
      </div>

      <aside class="product-hero__side">
        {p.image && (
          <img src={url(p.image)} alt={`Logo ${p.name}`} class="product-badge" width="220" height="220" />
        )}
        <div class="price-card card">
          {p.free ? (
            <span class="badge badge--free">Gratuit</span>
          ) : comingSoon ? (
            <span class="badge">Bientôt</span>
          ) : (
            <span class="badge">Licence perpétuelle</span>
          )}
          <div class="price-card__price">{p.price}</div>
          <p class="text-muted">{p.priceNote}</p>
          {comingSoon ? (
            <span class="btn btn--primary btn--block is-disabled" aria-disabled="true">Bientôt disponible</span>
          ) : (
            <a href={ctaHref} class="btn btn--primary btn--block" {...ctaAttrs}>{ctaLabel}</a>
          )}
        </div>
      </aside>
    </div>
  </section>

  <section class="section section--soft">
    <div class="container">
      {p.benefits ? (
        <div class="intro">
          <h2>En bref</h2>
          <p class="lead" style="margin-top: 0.75rem;">{p.summary}</p>
        </div>
      ) : (
        <div class="product-body">
          <div>
            <h2>En bref</h2>
            <p class="lead" style="margin-top: 0.75rem;">{p.summary}</p>
          </div>
          <div>
            <h2>Ce qu'il fait</h2>
            <ul class="feature-list">
              {p.features.map((f) => <li>{f}</li>)}
            </ul>
          </div>
        </div>
      )}
    </div>
  </section>

  {p.benefits && (
    <section class="section">
      <div class="container">
        <header class="section-head">
          <span class="eyebrow">Vos avantages</span>
          <h2>Pourquoi vous allez l'adopter</h2>
        </header>
        <div class="grid grid--3" style="margin-top: 2.5rem;">
          {p.benefits.map((b) => (
            <div class="card">
              <h3>{b.title}</h3>
              <p class="text-muted" style="margin-top: 0.5rem;">{b.text}</p>
            </div>
          ))}
        </div>
      </div>
    </section>
  )}

  {p.steps && (
    <section class="section section--soft">
      <div class="container">
        <header class="section-head">
          <span class="eyebrow">Aussi simple que ça</span>
          <h2>Comment ça marche</h2>
        </header>
        <ol class="steps">
          {p.steps.map((s, i) => (
            <li>
              <span class="steps__n">{i + 1}</span>
              <p>{s}</p>
            </li>
          ))}
        </ol>
        <div style="margin-top: 2.5rem;">
          {comingSoon ? (
            <span class="btn btn--primary is-disabled" aria-disabled="true">Bientôt disponible</span>
          ) : (
            <a href={ctaHref} class="btn btn--primary" {...ctaAttrs}>{ctaLabel}</a>
          )}
        </div>
      </div>
    </section>
  )}

  <section class="section">
    <div class="container">
      <div class="diff card">
        <span class="eyebrow">Pourquoi cet outil</span>
        <p class="lead" style="margin-top: 0.75rem;">{p.differentiator}</p>
      </div>
    </div>
  </section>
</Base>

<style>
  .product-hero { padding-block: clamp(3rem, 8vw, 5rem); }
  .product-hero__inner {
    display: grid;
    grid-template-columns: 1.6fr 1fr;
    gap: 2.5rem;
    align-items: start;
  }
  .back-link {
    display: block;
    width: fit-content;
    color: var(--text-muted);
    font-size: 0.9rem;
    margin-bottom: 1.75rem;
  }
  .back-link:hover { color: var(--accent); }
  .product-hero h1 { margin-top: 0.6rem; }
  .product-hero .lead { margin-top: 1rem; }
  .product-hero__pitch { margin-top: 1.1rem; max-width: 54ch; line-height: 1.7; }

  .hero-points {
    list-style: none;
    padding: 0;
    margin-top: 1.5rem;
    display: grid;
    gap: 0.7rem;
    max-width: 54ch;
  }
  .hero-points li {
    position: relative;
    padding-left: 1.9rem;
    color: var(--text);
  }
  .hero-points li::before {
    content: '✓';
    position: absolute;
    left: 0;
    top: -0.05rem;
    color: var(--accent);
    font-weight: 700;
  }
  .product-hero__cta { display: flex; align-items: center; gap: 1rem; margin-top: 2.25rem; flex-wrap: wrap; }

  .product-hero__side {
    position: sticky;
    top: 90px;
    display: flex;
    flex-direction: column;
    align-items: center;
    gap: 1.75rem;
  }
  .product-badge {
    width: clamp(170px, 16vw, 230px);
    height: auto;
    filter: drop-shadow(0 12px 40px rgba(194, 131, 44, 0.25));
  }
  .price-card { width: 100%; display: flex; flex-direction: column; gap: 0.75rem; }
  .price-card__price { font-size: 2.4rem; font-weight: 800; }

  .product-body { display: grid; grid-template-columns: 1fr 1fr; gap: 2.5rem; }
  .intro { max-width: 68ch; }

  .steps { list-style: none; padding: 0; margin-top: 2.5rem; display: grid; gap: 1.25rem; max-width: 760px; }
  .steps li { display: flex; align-items: center; gap: 1.1rem; }
  .steps__n {
    flex: none;
    display: inline-flex; align-items: center; justify-content: center;
    width: 2.4rem; height: 2.4rem;
    border-radius: 999px;
    background: var(--accent-soft);
    color: var(--accent);
    font-weight: 700;
  }
  .steps li p { font-size: 1.1rem; }

  .feature-list { list-style: none; padding: 0; margin-top: 0.75rem; display: grid; gap: 0.75rem; }
  .feature-list li {
    position: relative;
    padding-left: 1.75rem;
    color: var(--text-muted);
  }
  .feature-list li::before {
    content: '';
    position: absolute;
    left: 0; top: 0.55rem;
    width: 8px; height: 8px;
    border-radius: 2px;
    background: var(--accent);
  }

  .diff { padding: 2rem; }

  .btn.is-disabled {
    opacity: 0.55;
    cursor: not-allowed;
    pointer-events: none;
  }

  @media (max-width: 820px) {
    .product-hero__inner, .product-body { grid-template-columns: 1fr; }
    .product-hero__side { position: static; }
  }
</style>
