---
import Base from '../layouts/Base.astro';
import { products, getProduct } from '../data/products';

export function getStaticPaths() {
  return products.map((p) => ({ params: { product: p.slug } }));
}

const { product } = Astro.params;
const p = getProduct(product!);
if (!p) return Astro.redirect('/404');

const ctaLabel = p.free ? 'Créer un compte gratuit' : `Acheter — ${p.price}`;
const ctaHref = p.free ? '/login' : '/login'; // TODO: brancher Lemon Squeezy
---

<Base title={`${p.name} — Arnisound Tools`} description={p.tagline}>
  <section class="product-hero">
    <div class="container product-hero__inner">
      <div>
        <a href="/" class="back-link">← Tous les outils</a>
        <span class="eyebrow" style="margin-top: 1rem;">{p.audience}</span>
        <h1>{p.name}</h1>
        <p class="lead">{p.tagline}</p>
        <div class="product-hero__cta">
          <a href={ctaHref} class="btn btn--primary">{ctaLabel}</a>
          {!p.free && <span class="text-muted">{p.priceNote}</span>}
        </div>
      </div>

      <aside class="price-card card">
        {p.free ? (
          <span class="badge badge--free">Gratuit</span>
        ) : (
          <span class="badge">Licence perpétuelle</span>
        )}
        <div class="price-card__price">{p.price}</div>
        <p class="text-muted">{p.priceNote}</p>
        <a href={ctaHref} class="btn btn--primary btn--block">{ctaLabel}</a>
      </aside>
    </div>
  </section>

  <section class="section section--soft">
    <div class="container product-body">
      <div>
        <h2>En bref</h2>
        <p class="lead" style="margin-top: 0.75rem;">{p.summary}</p>
      </div>
      <div>
        <h2>Ce qu'il fait</h2>
        <ul class="feature-list">
          {p.features.map((f) => <li>{f}</li>)}
        </ul>
      </div>
    </div>
  </section>

  <section class="section">
    <div class="container">
      <div class="diff card">
        <span class="eyebrow">Pourquoi cet outil</span>
        <p class="lead" style="margin-top: 0.75rem;">{p.differentiator}</p>
      </div>
    </div>
  </section>
</Base>

<style>
  .product-hero { padding-block: clamp(3rem, 8vw, 5rem); }
  .product-hero__inner {
    display: grid;
    grid-template-columns: 1.6fr 1fr;
    gap: 2.5rem;
    align-items: start;
  }
  .back-link { color: var(--text-muted); font-size: 0.9rem; }
  .back-link:hover { color: var(--accent); }
  .product-hero h1 { margin-top: 0.5rem; }
  .product-hero .lead { margin-top: 1rem; }
  .product-hero__cta { display: flex; align-items: center; gap: 1rem; margin-top: 2rem; flex-wrap: wrap; }

  .price-card { position: sticky; top: 90px; display: flex; flex-direction: column; gap: 0.75rem; }
  .price-card__price { font-size: 2.4rem; font-weight: 800; }

  .product-body { display: grid; grid-template-columns: 1fr 1fr; gap: 2.5rem; }

  .feature-list { list-style: none; padding: 0; margin-top: 0.75rem; display: grid; gap: 0.75rem; }
  .feature-list li {
    position: relative;
    padding-left: 1.75rem;
    color: var(--text-muted);
  }
  .feature-list li::before {
    content: '';
    position: absolute;
    left: 0; top: 0.55rem;
    width: 8px; height: 8px;
    border-radius: 2px;
    background: var(--accent);
  }

  .diff { padding: 2rem; }

  @media (max-width: 820px) {
    .product-hero__inner, .product-body { grid-template-columns: 1fr; }
    .price-card { position: static; }
  }
</style>
