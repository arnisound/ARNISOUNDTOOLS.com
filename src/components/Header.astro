---
import { url } from '../lib/site';
import { products } from '../data/products';
const { pathname } = Astro.url;
const base = import.meta.env.BASE_URL.replace(/\/$/, '');

const order = ['speed-rf', 'rf-shot', 'av-calc', 'fiche-tech', 'reperages'];
const tools = order
  .map((slug) => products.find((p) => p.slug === slug))
  .filter((p): p is (typeof products)[number] => Boolean(p));

const isActive = (href: string) =>
  pathname === base + href || pathname === base + href + '/';
const toolsActive = tools.some((t) => isActive('/' + t.slug));
---

<header class="site-header">
  <div class="container site-header__inner">
    <a href={url('/')} class="brand" aria-label="Arnisound Tools — accueil">
      <img src={url('/logo.svg')} alt="Arnisound Tools" class="brand__logo" width="223" height="41" />
    </a>

    <nav class="nav" aria-label="Navigation principale">
      <div class="nav__group" data-dropdown>
        <button type="button" class:list={['nav__link', 'nav__trigger', { 'is-active': toolsActive }]} aria-haspopup="true" aria-expanded="false">
          Outils <span class="nav__caret" aria-hidden="true">▾</span>
        </button>
        <div class="nav__menu">
          {tools.map((t) => (
            <a href={url('/' + t.slug)} class="nav__menu-item">
              {t.image && <img src={url(t.image)} alt="" width="30" height="30" />}
              <span>{t.name}</span>
              {t.comingSoon && <span class="nav__tag">Bientôt</span>}
            </a>
          ))}
        </div>
      </div>
      <a href={url('/a-propos')} class:list={['nav__link', { 'is-active': isActive('/a-propos') }]}>À propos</a>
    </nav>

    <div class="site-header__actions">
      <a href={url('/login')} class="btn btn--ghost" data-auth-link>Connexion</a>
    </div>

    <button class="nav-toggle" aria-label="Ouvrir le menu" aria-expanded="false" data-nav-toggle>
      <span></span><span></span><span></span>
    </button>
  </div>

  <div class="mobile-nav" data-mobile-nav hidden>
    <span class="mobile-nav__label">Outils</span>
    {tools.map((t) => (
      <a href={url('/' + t.slug)} class="mobile-nav__link mobile-nav__link--tool">{t.name}{t.comingSoon && <span class="nav__tag">Bientôt</span>}</a>
    ))}
    <a href={url('/a-propos')} class="mobile-nav__link">À propos</a>
    <a href={url('/login')} class="btn btn--primary btn--block" data-auth-link>Connexion</a>
  </div>
</header>

<style>
  .site-header {
    position: sticky;
    top: 0;
    z-index: 50;
    background:
      linear-gradient(180deg, rgba(255, 255, 255, 0.05), rgba(255, 255, 255, 0)),
      rgba(12, 12, 14, 0.85);
    backdrop-filter: blur(12px);
    border-bottom: 1px solid var(--border);
    box-shadow: inset 0 1px 0 rgba(255, 255, 255, 0.06);
  }
  .site-header__inner {
    display: flex;
    align-items: center;
    justify-content: space-between;
    gap: 1.5rem;
    height: 68px;
  }
  .brand { display: inline-flex; align-items: center; }
  .brand__logo { height: 38px; width: auto; display: block; }
  @media (max-width: 520px) { .brand__logo { height: 32px; } }

  .nav { display: flex; align-items: center; gap: 0.4rem; margin-inline: auto; }
  .nav__link {
    padding: 0.5rem 0.85rem;
    border-radius: var(--radius-sm);
    color: var(--text-muted);
    font-size: 0.92rem;
    font-weight: 500;
    transition: color 0.15s ease, background 0.15s ease;
  }
  .nav__link:hover { color: var(--text); background: var(--surface); }
  .nav__link.is-active { color: var(--accent); }

  /* Menu déroulant « Outils » */
  .nav__group { position: relative; }
  .nav__trigger {
    display: inline-flex; align-items: center; gap: 0.35rem;
    background: none; border: none; cursor: pointer; font: inherit;
  }
  .nav__caret { font-size: 0.7em; transition: transform 0.18s ease; }
  .nav__menu {
    position: absolute;
    top: calc(100% + 6px);
    left: 50%;
    transform: translateX(-50%) translateY(-6px);
    min-width: 240px;
    background: var(--bg-soft);
    border: 1px solid var(--border);
    border-radius: var(--radius);
    padding: 0.4rem;
    display: grid; gap: 2px;
    opacity: 0; visibility: hidden;
    transition: opacity 0.15s ease, transform 0.15s ease, visibility 0.15s;
    box-shadow: 0 16px 40px rgba(0, 0, 0, 0.4);
    z-index: 60;
  }
  .nav__menu::before { content: ''; position: absolute; top: -8px; left: 0; right: 0; height: 8px; }
  .nav__group:hover .nav__menu,
  .nav__group:focus-within .nav__menu,
  .nav__group[data-open] .nav__menu {
    opacity: 1; visibility: visible; transform: translateX(-50%) translateY(0);
  }
  .nav__group:hover .nav__caret,
  .nav__group[data-open] .nav__caret { transform: rotate(180deg); }
  .nav__menu-item {
    display: flex; align-items: center; gap: 0.65rem;
    padding: 0.55rem 0.7rem; border-radius: 9px;
    color: var(--text-muted); font-size: 0.92rem; font-weight: 500;
  }
  .nav__menu-item:hover { background: var(--surface); color: var(--text); }
  .nav__menu-item img { width: 30px; height: 30px; flex: none; }
  .nav__tag {
    margin-left: auto; font-size: 0.68rem; color: var(--text-faint);
    border: 1px solid var(--border); border-radius: 999px; padding: 0.05rem 0.5rem;
  }

  .site-header__actions { display: flex; }
  .site-header__actions .btn { padding: 0.55rem 1.1rem; }

  .nav-toggle {
    display: none;
    flex-direction: column;
    gap: 5px;
    background: none;
    border: none;
    padding: 6px;
  }
  .nav-toggle span {
    width: 24px; height: 2px;
    background: var(--text);
    border-radius: 2px;
    transition: transform 0.2s ease, opacity 0.2s ease;
  }

  .mobile-nav {
    display: none;
    flex-direction: column;
    gap: 0.4rem;
    padding: 1rem var(--gutter) 1.5rem;
    border-bottom: 1px solid var(--border);
    background: var(--bg-soft);
  }
  .mobile-nav__label {
    font-size: 0.72rem; text-transform: uppercase; letter-spacing: 0.12em;
    color: var(--text-faint); padding: 0.5rem 0.5rem 0.1rem;
  }
  .mobile-nav__link {
    display: flex; align-items: center; gap: 0.5rem;
    padding: 0.7rem 0.5rem;
    color: var(--text-muted);
    border-bottom: 1px solid var(--border);
  }
  .mobile-nav__link--tool { padding-left: 1.1rem; }
  .mobile-nav__link:hover { color: var(--text); }

  @media (max-width: 860px) {
    .nav, .site-header__actions { display: none; }
    .nav-toggle { display: flex; }
    .mobile-nav[data-open] { display: flex; }
  }
</style>

<script>
  const toggle = document.querySelector('[data-nav-toggle]');
  const menu = document.querySelector('[data-mobile-nav]');
  toggle?.addEventListener('click', () => {
    const open = menu?.hasAttribute('data-open');
    if (open) {
      menu?.removeAttribute('data-open');
      menu?.setAttribute('hidden', '');
      toggle.setAttribute('aria-expanded', 'false');
    } else {
      menu?.setAttribute('data-open', '');
      menu?.removeAttribute('hidden');
      toggle.setAttribute('aria-expanded', 'true');
    }
  });

  // Menu « Outils » : clic pour ouvrir/fermer (tactile), en plus du survol.
  const dd = document.querySelector('[data-dropdown]');
  const trigger = dd?.querySelector('.nav__trigger');
  trigger?.addEventListener('click', (e) => {
    e.preventDefault();
    const open = dd!.hasAttribute('data-open');
    dd!.toggleAttribute('data-open', !open);
    trigger.setAttribute('aria-expanded', String(!open));
  });
  document.addEventListener('click', (e) => {
    if (dd && !dd.contains(e.target as Node)) {
      dd.removeAttribute('data-open');
      trigger?.setAttribute('aria-expanded', 'false');
    }
  });
</script>

<script>
  // Bandeau conscient de la session : « Connexion » ↔ « Mon compte ».
  import { supabase } from '../lib/supabase';
  const base = import.meta.env.BASE_URL.replace(/\/$/, '');
  async function refreshAuthLinks() {
    const { data: { session } } = await supabase.auth.getSession();
    document.querySelectorAll<HTMLAnchorElement>('[data-auth-link]').forEach((a) => {
      if (session) {
        a.href = base + '/dashboard';
        a.textContent = 'Mon compte';
      } else {
        a.href = base + '/login';
        a.textContent = 'Connexion';
      }
    });
  }
  refreshAuthLinks();
  supabase.auth.onAuthStateChange(() => refreshAuthLinks());
</script>
