---
import '../styles/global.css';
import Header from '../components/Header.astro';
import Footer from '../components/Footer.astro';
import { url } from '../lib/site';

interface Props {
  title?: string;
  description?: string;
  /** Masque l'en-tête/pied (pages app immersives type login/dashboard) */
  bare?: boolean;
}

const {
  title = 'Arnisound Tools — Les outils du terrain',
  description = "Suite d'outils web professionnels pour le spectacle vivant et l'événementiel. Simples, en français, pensés pour le terrain.",
  bare = false,
} = Astro.props;

const site = Astro.site ?? new URL('https://arnisoundtools.com');
const ogImage = new URL(url('/og.png'), site).href;
const canonical = new URL(Astro.url.pathname, site).href;
---

<!doctype html>
<html lang="fr">
  <head>
    <meta charset="utf-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1" />
    <link rel="icon" type="image/svg+xml" href={url('/favicon.svg')} />
    <link rel="apple-touch-icon" href={url('/favicon.svg')} />
    <title>{title}</title>
    <meta name="description" content={description} />
    <link rel="canonical" href={canonical} />
    <meta property="og:title" content={title} />
    <meta property="og:description" content={description} />
    <meta property="og:type" content="website" />
    <meta property="og:url" content={canonical} />
    <meta property="og:site_name" content="Arnisound Tools" />
    <meta property="og:locale" content="fr_FR" />
    <meta property="og:image" content={ogImage} />
    <meta property="og:image:width" content="1200" />
    <meta property="og:image:height" content="630" />
    <meta property="og:image:alt" content="Arnisound Tools — les outils du terrain" />
    <meta name="twitter:card" content="summary_large_image" />
    <meta name="twitter:title" content={title} />
    <meta name="twitter:description" content={description} />
    <meta name="twitter:image" content={ogImage} />
    <link rel="preconnect" href="https://fonts.googleapis.com" />
    <link rel="preconnect" href="https://fonts.gstatic.com" crossorigin />
    <link
      href="https://fonts.googleapis.com/css2?family=Inter:wght@400;500;600;700;800&family=JetBrains+Mono:wght@400;600&display=swap"
      rel="stylesheet"
    />
  </head>
  <body>
    {!bare && <Header />}
    <main>
      <slot />
    </main>
    {!bare && <Footer />}
  </body>
</html>
