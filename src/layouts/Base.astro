---
import '../styles/global.css';
import Header from '../components/Header.astro';
import Footer from '../components/Footer.astro';

interface Props {
  title?: string;
  description?: string;
  /** Masque l'en-tête/pied (pages app immersives type login/dashboard) */
  bare?: boolean;
}

const {
  title = 'Arnisound Tools — Les outils du terrain',
  description = "Suite d'outils web professionnels pour le spectacle vivant et l'événementiel. Simples, en français, pensés pour le terrain.",
  bare = false,
} = Astro.props;
---

<!doctype html>
<html lang="fr">
  <head>
    <meta charset="utf-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1" />
    <link rel="icon" type="image/svg+xml" href="/logo.svg" />
    <title>{title}</title>
    <meta name="description" content={description} />
    <meta property="og:title" content={title} />
    <meta property="og:description" content={description} />
    <meta property="og:type" content="website" />
    <link rel="preconnect" href="https://fonts.googleapis.com" />
    <link rel="preconnect" href="https://fonts.gstatic.com" crossorigin />
    <link
      href="https://fonts.googleapis.com/css2?family=Inter:wght@400;500;600;700;800&family=JetBrains+Mono:wght@400;600&display=swap"
      rel="stylesheet"
    />
  </head>
  <body>
    {!bare && <Header />}
    <main>
      <slot />
    </main>
    {!bare && <Footer />}
  </body>
</html>
